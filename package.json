{
  "name": "openclaw-data-board",
  "version": "1.0.0",
  "description": "Safety-first local data board for OpenClaw observability, task operations, and operator review.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:api": "cross-env UI_MODE=true node --import tsx src/index.ts",
    "dev:frontend": "cd frontend && pnpm dev",
    "dev": "concurrently --kill-others --names \"API,FRONTEND\" --prefix-colors \"auto\" \"npm run dev:api\" \"npm run dev:frontend\"",
    "build:frontend": "cd frontend && pnpm build",
    "build": "npm run build:frontend && tsc -p tsconfig.json",
    "preview": "cd frontend && pnpm preview",
    "clean": "Remove-Item -Recurse -Force node_modules, frontend\\node_modules, .vite, dist -ErrorAction SilentlyContinue"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^22.13.10",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "svelte": "^5.25.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "esbuild": "^0.27.4",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1",
    "serve-static": "^1.16.2"
  }
}
